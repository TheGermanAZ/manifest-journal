# Convex
CONVEX_DEPLOYMENT=dev:your-deployment-name     # from `bunx convex dev`
VITE_CONVEX_URL=https://your-deployment.convex.cloud
VITE_CONVEX_SITE_URL=https://your-deployment.convex.site

# Better Auth
BETTER_AUTH_SECRET=           # random string: `openssl rand -hex 32`

# Frontend origin — used for CORS + cross-domain OAuth redirects
# Defaults to http://localhost:3000 if unset
# CLIENT_ORIGIN=https://your-production-domain.com

# Discord OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Resend (magic link emails)
AUTH_RESEND_KEY=

# OpenRouter (AI journaling features via OpenAI-compatible API)
OPENROUTER_API_KEY=
